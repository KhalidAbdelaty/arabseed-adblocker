{
  "manifest_version": 3,
  "name": "ArabSeed Shield",
  "short_name": "ArabShield",
  "version": "1.1.0",
  "description": "ArabSeed-focused ad blocker and anti-detection shield by Khalid Abdelaty. Local-only, no telemetry, no remote code.",
  "minimum_chrome_version": "111",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [],

  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },

  "action": {
    "default_title": "ArabSeed Shield",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["target_config.js", "content_script.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://asd.ink/*",
        "*://*.asd.ink/*",
        "*://asd.homes/*",
        "*://*.asd.homes/*",
        "*://arabseed.com/*",
        "*://*.arabseed.com/*",
        "*://arabseed.net/*",
        "*://*.arabseed.net/*",
        "*://arabseed.sbs/*",
        "*://*.arabseed.sbs/*",
        "*://arabseed.ink/*",
        "*://*.arabseed.ink/*",
        "*://arabseed.one/*",
        "*://*.arabseed.one/*",
        "*://arabseed.co/*",
        "*://*.arabseed.co/*",
        "*://arabseed.tv/*",
        "*://*.arabseed.tv/*",
        "*://reviewrate.net/*",
        "*://*.reviewrate.net/*",
        "*://reviewtech.me/*",
        "*://*.reviewtech.me/*",
        "*://arabseed.me/*",
        "*://*.arabseed.me/*",
        "*://arabseed.show/*",
        "*://*.arabseed.show/*",
        "*://arabseed.xyz/*",
        "*://*.arabseed.xyz/*",
        "*://arabseed.onl/*",
        "*://*.arabseed.onl/*",
        "*://arabseed.wiki/*",
        "*://*.arabseed.wiki/*",
        "*://arabseed.lol/*",
        "*://*.arabseed.lol/*",
        "*://seeeed.xyz/*",
        "*://*.seeeed.xyz/*",
        "*://fredl.ru/*",
        "*://*.fredl.ru/*",
        "*://filespayouts.com/*",
        "*://*.filespayouts.com/*",
        "*://usersdrive.com/*",
        "*://*.usersdrive.com/*",
        "*://up-4ever.net/*",
        "*://*.up-4ever.net/*",
        "*://up4ever.com/*",
        "*://*.up4ever.com/*",
        "*://up4ever.net/*",
        "*://*.up4ever.net/*",
        "*://filemoon.sx/*",
        "*://*.filemoon.sx/*",
        "*://savefiles.com/*",
        "*://*.savefiles.com/*",
        "*://up4fun.top/*",
        "*://*.up4fun.top/*",
        "*://ups2up.fun/*",
        "*://*.ups2up.fun/*",
        "*://ups2up.top/*",
        "*://*.ups2up.top/*",
        "*://vidmoly.me/*",
        "*://*.vidmoly.me/*",
        "*://vidmoly.net/*",
        "*://*.vidmoly.net/*",
        "*://vidmoly.biz/*",
        "*://*.vidmoly.biz/*",
        "*://vidara.to/*",
        "*://*.vidara.to/*",
        "*://voe.sx/*",
        "*://*.voe.sx/*",
        "*://byse.sx/*",
        "*://*.byse.sx/*",
        "*://bysezejataos.com/*",
        "*://*.bysezejataos.com/*",
        "*://bysevepoin.com/*",
        "*://*.bysevepoin.com/*",
        "*://stmix.io/*",
        "*://*.stmix.io/*",
        "*://f75s.com/*",
        "*://*.f75s.com/*",
        "*://luluvdo.com/*",
        "*://*.luluvdo.com/*",
        "*://luluvid.com/*",
        "*://*.luluvid.com/*",
        "*://frdl.io/*",
        "*://*.frdl.io/*"
      ],
      "js": ["target_config.js", "page_world_guard.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "static_rules",
        "enabled": true,
        "path": "rules/static_rules.json"
      },
      {
        "id": "strict_rules",
        "enabled": false,
        "path": "rules/strict_rules.json"
      }
    ]
  }
}
